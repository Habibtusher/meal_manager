generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  type               String              @default("mess")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  expenses           Expense[]
  mealSchedules      MealSchedule[]
  sharedCosts        SharedCost[]
  users              User[]
  walletTransactions WalletTransaction[]

  @@map("organizations")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  password              String
  name                  String
  role                  Role                   @default(MEMBER)
  emailVerified         DateTime?
  walletBalance         Float                  @default(0)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  organizationId        String?
  roomRent              Float                  @default(0)
  mealRecords           MealRecord[]
  sharedCostAllocations SharedCostAllocation[]
  supportTickets        SupportTicket[]
  organization          Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  walletTransactions    WalletTransaction[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model MealSchedule {
  id             String       @id @default(cuid())
  date           DateTime
  mealType       MealType
  menu           String
  description    String?
  price          Float
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  mealRecords    MealRecord[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, mealType])
  @@index([organizationId, date])
  @@map("meal_schedules")
}

model MealRecord {
  id             String       @id @default(cuid())
  date           DateTime
  mealType       MealType
  count          Float        @default(0)
  status         MealStatus   @default(PENDING)
  markedBy       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String
  mealScheduleId String
  mealSchedule   MealSchedule @relation(fields: [mealScheduleId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mealScheduleId])
  @@index([userId, date])
  @@index([mealScheduleId])
  @@map("meal_records")
}

model Expense {
  id             String       @id @default(cuid())
  date           DateTime
  category       String
  description    String
  amount         Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@map("expenses")
}

model WalletTransaction {
  id             String          @id @default(cuid())
  type           TransactionType
  amount         Float
  description    String
  balanceAfter   Float
  createdAt      DateTime        @default(now())
  userId         String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([organizationId])
  @@map("wallet_transactions")
}

model SupportTicket {
  id        String   @id @default(cuid())
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("support_tickets")
}

model SharedCost {
  id             String                 @id @default(cuid())
  amount         Float
  description    String
  date           DateTime
  category       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organizationId String
  allocations    SharedCostAllocation[]
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@map("shared_costs")
}

model SharedCostAllocation {
  id           String     @id @default(cuid())
  amount       Float
  userId       String
  sharedCostId String
  sharedCost   SharedCost @relation(fields: [sharedCostId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sharedCostId])
  @@map("shared_cost_allocations")
}

enum Role {
  ADMIN
  MEMBER
  SUPER_ADMIN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum MealStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TransactionType {
  CREDIT
  DEBIT
}
